{
  "name": "localsprite",
  "version": "0.0.0",
  "description": "Local + MCP-server testing agent. Functional sibling of TestSprite, no API key, Node/TS projects.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "localsprite": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke-localsprite.mjs",
    "mcp": "node dist/mcp/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.9.0",
    "dockerode": "^4.0.0",
    "playwright": "^1.49.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^3.3.0",
    "@types/node": "^24.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
